```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.class
*.exe
*.dll
*.so
*.a
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
*.env.*

# Build directories
dist/
build/
target/
*.jar
*.war
*.zip
*.tar.gz

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# System files
.DS_Store
Thumbs.db

# Logs
*.log

# Coverage
coverage/
htmlcov/
.coverage

# Python specific
*.pyc
__pycache__/
.pytest_cache/
.mypy_cache/

# Node.js specific
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

```